{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mutsumi-s PRES",
  "version": "0.0.0",
  "identifier": "com.mutsumi.pres",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mutsumi's PRES",
        "width": 960,
        "height": 620,
        "minWidth": 800,
        "minHeight": 480,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4ODBGRUNEMjYxRTBGMTEKUldRUkR4NG16ZjZBT0U1UHdZc0Z0KzNScElQcFFCanVCUnRhOHVLa3EwQXlhSFN6RUVBdG82UlEK",
      "endpoints": [
        "https://github.com/GYPp1us/Mutsumi-s-PERS/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}